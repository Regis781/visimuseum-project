<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!--
    ARCHITECTURE SEO — SPA monopage avec langue via paramètre ?lang=
    ────────────────────────────────────────────────────────────────
    Choix retenu : une seule URL canonique (la racine /) soumise à Google.
    Les variantes ?lang=fr et ?lang=es sont déclarées uniquement en hreflang
    (balises <link> dans le <head> du HTML) et NON comme des <url> séparées
    dans ce sitemap. Raison : Google détectait une redirection logique car la
    canonical dans index.html pointait toujours vers / — ce qui empêchait
    l'indexation de ?lang=fr et ?lang=es.
    Cette architecture évite le problème « Page avec redirection » signalé
    dans la Search Console.
  -->

  <!-- Page principale — version anglaise par défaut -->
  <url>
    <loc>https://www.visimuseum.com/</loc>
    <lastmod>2026-05-07</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    <!-- Signaux hreflang : indique aux moteurs les équivalents linguistiques -->
    <xhtml:link rel="alternate" hreflang="en"        href="https://www.visimuseum.com/"/>
    <xhtml:link rel="alternate" hreflang="fr"        href="https://www.visimuseum.com/?lang=fr"/>
    <xhtml:link rel="alternate" hreflang="es"        href="https://www.visimuseum.com/?lang=es"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="https://www.visimuseum.com/"/>
  </url>

</urlset>
